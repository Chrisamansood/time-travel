*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#111418;--card:#0d1117;--border:#1e2329;--divider:#2a3038;
  --text:#F0F6FC;--muted:#444c56;--secondary:#9198a1;--accent:#00D26A;
  --red:#f85149;--amber:#d29922;--green:#00D26A;
  --mono:ui-monospace,'Courier New',monospace;
  --sans:system-ui,-apple-system,sans-serif;
}
html{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:15px;line-height:1.6}
body{max-width:1400px;margin:0 auto;padding:0 32px 48px}
a{color:var(--accent);text-decoration:none}
a:hover{text-decoration:underline}

/* ── top bar ─────────────────────────────────── */
.tt-top{height:3px;background:var(--accent)}
.tt-bot{height:2px;background:var(--accent);opacity:.35;margin-top:48px}

/* ── header ──────────────────────────────────── */
.tt-header{padding:32px 0 24px;border-bottom:1px solid var(--border)}
.tt-header h1{font-family:var(--mono);font-size:1.1rem;font-weight:600;letter-spacing:.5px}
.tt-header h1 .accent{color:var(--accent)}
.tt-header-meta{display:flex;justify-content:space-between;align-items:baseline;margin-top:8px;font-size:.85rem;color:var(--secondary)}
.tt-dl-links{display:flex;gap:16px;margin-top:12px}
.tt-dl-links a{font-family:var(--mono);font-size:.8rem;color:var(--secondary);border:1px solid var(--border);padding:4px 12px}
.tt-dl-links a:hover{color:var(--accent);border-color:var(--accent);text-decoration:none}

/* ── section labels ──────────────────────────── */
.tt-label{font-family:var(--mono);font-size:.7rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin:32px 0 16px}
.tt-label::before{content:'// '}
.tt-divider{border:none;border-top:1px solid var(--divider);margin:32px 0}

/* ── confidence bar ──────────────────────────── */
.tt-confidence{padding:24px 0;border-bottom:1px solid var(--border)}
.tt-conf-row{display:flex;align-items:center;gap:16px;font-family:var(--mono);font-size:.95rem}
.tt-conf-label{min-width:140px;color:var(--secondary)}
.tt-conf-val{font-weight:700;min-width:48px;text-align:right}
.tt-conf-bar{flex:1;height:8px;background:var(--border);position:relative}
.tt-conf-fill{height:100%;transition:width .3s}
.tt-conf-fill.unmit{background:var(--red)}
.tt-conf-fill.mit{background:var(--accent)}
.tt-conf-lift{font-family:var(--mono);font-size:.85rem;color:var(--accent);margin-top:8px}

/* ── main layout ─────────────────────────────── */
.tt-main{display:grid;grid-template-columns:200px 1fr;gap:0;margin-top:0;border-bottom:1px solid var(--border)}
.tt-rail{border-right:1px solid var(--border);padding:24px 16px 24px 0}
.tt-center{padding:24px 0 24px 24px}

/* ── persona chips ───────────────────────────── */
.tt-chip{font-family:var(--mono);font-size:.8rem;color:var(--secondary);padding:6px 0;border-bottom:1px solid var(--border)}
.tt-chip:last-child{border-bottom:none}

/* ── horizon dots ────────────────────────────── */
.tt-horizon{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:.8rem;color:var(--secondary);padding:4px 0}
.tt-hdot{width:8px;height:8px;border-radius:50%;display:inline-block}
.tt-hdot.h-short{background:var(--red)}
.tt-hdot.h-mid{background:var(--amber)}
.tt-hdot.h-long{background:var(--green)}

/* ── tab bar ─────────────────────────────────── */
.tt-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:20px}
.tt-tab{font-family:var(--mono);font-size:.8rem;letter-spacing:1px;text-transform:uppercase;color:var(--secondary);padding:8px 16px;cursor:pointer;border-bottom:2px solid transparent;background:none;border-top:none;border-left:none;border-right:none}
.tt-tab:hover{color:var(--text)}
.tt-tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.tt-tabpanel{display:none}
.tt-tabpanel.active{display:block}

/* ── risk cards ──────────────────────────────── */
.tt-risk{background:var(--card);border:1px solid var(--border);padding:16px 20px;margin-bottom:12px}
.tt-risk-head{display:flex;align-items:baseline;gap:12px;margin-bottom:8px}
.tt-risk-num{font-family:var(--mono);font-size:1.4rem;font-weight:700;color:var(--accent)}
.tt-risk-title{font-family:var(--mono);font-size:.95rem;font-weight:600}
.tt-risk-desc{font-size:.9rem;color:var(--secondary);margin-bottom:12px;line-height:1.5}
.tt-risk-meta{display:flex;gap:24px;flex-wrap:wrap;font-family:var(--mono);font-size:.75rem;color:var(--muted)}
.tt-risk-meta span{display:flex;align-items:center;gap:4px}

/* ── severity dots ───────────────────────────── */
.tt-sev{display:flex;gap:16px;margin:12px 0;flex-wrap:wrap}
.tt-si{display:flex;align-items:center;gap:4px;font-family:var(--mono);font-size:.7rem;color:var(--muted)}
.tt-d{width:8px;height:8px;border-radius:50%;background:var(--border);display:inline-block}
.tt-d.r{background:var(--red)}
.tt-d.a{background:var(--amber)}
.tt-d.g{background:var(--green)}

/* ── inflated / buried cards ─────────────────── */
.tt-inflated .tt-risk-num{color:var(--amber)}
.tt-buried .tt-risk-num{color:var(--secondary)}

/* ── user pov grid ───────────────────────────── */
.tt-userpov{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:32px}
.tt-pov-card{background:var(--card);border:1px solid var(--border);padding:16px 20px}
.tt-pov-label{font-family:var(--mono);font-size:.7rem;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.tt-pov-text{font-size:.9rem;color:var(--text);line-height:1.5}

/* ── mitigations grid ────────────────────────── */
.tt-mits{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:32px}
.tt-mit{background:var(--card);border:1px solid var(--border);padding:14px 18px}
.tt-mit-num{font-family:var(--mono);font-size:.8rem;color:var(--accent);font-weight:700}
.tt-mit-action{font-size:.85rem;color:var(--text);margin-top:4px}
.tt-mit-owner{font-family:var(--mono);font-size:.75rem;color:var(--muted);margin-top:6px}

/* ── evidence & methodology ──────────────────── */
.tt-bottom{display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-bottom:32px}
.tt-evidence-item{border-bottom:1px solid var(--border);padding:12px 0}
.tt-evidence-item:last-child{border-bottom:none}
.tt-ev-title{font-family:var(--mono);font-size:.85rem;font-weight:600}
.tt-ev-detail{font-size:.8rem;color:var(--secondary);margin-top:4px}
.tt-method-row{font-family:var(--mono);font-size:.8rem;color:var(--secondary);padding:4px 0}
.tt-method-row .k{color:var(--muted)}
.tt-method-row .v{color:var(--text)}

/* ── footer ──────────────────────────────────── */
.tt-footer{border-top:1px solid var(--border);padding:24px 0;display:flex;justify-content:space-between;align-items:center;font-family:var(--mono);font-size:.8rem;color:var(--secondary)}
.tt-footer-links{display:flex;gap:16px}
.tt-footer-links a{color:var(--secondary)}
.tt-footer-links a:hover{color:var(--accent)}

/* ── narrow screen notice ────────────────────── */
.tt-narrow{display:none;font-family:var(--mono);font-size:.85rem;color:var(--muted);text-align:center;padding:48px 24px}
@media(max-width:900px){
  .tt-narrow{display:block}
  .tt-top,.tt-header,.tt-confidence,.tt-main,.tt-userpov,.tt-mits,.tt-bottom,.tt-footer,.tt-bot,
  .tt-label,.tt-divider,.tt-dl-links{display:none}
}
