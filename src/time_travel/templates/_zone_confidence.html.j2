<div class="tt-confidence">
  <div class="tt-conf-row">
    <span class="tt-conf-label">UNMITIGATED</span>
    <span class="tt-conf-val" style="color:var(--red)">{{ unmitigated_band }}</span>
    <div class="tt-conf-bar"><div class="tt-conf-fill unmit band-{{ unmitigated_band | lower }}"></div></div>
  </div>
  <div class="tt-conf-row" style="margin-top:8px">
    <span class="tt-conf-label">MITIGATED</span>
    <span class="tt-conf-val" style="color:var(--accent)">{{ mitigated_band }}</span>
    <div class="tt-conf-bar"><div class="tt-conf-fill mit band-{{ mitigated_band | lower }}"></div></div>
  </div>
  <div class="tt-conf-lift">{{ confidence_drivers }} · {{ report.mitigations | length }} mitigations applied</div>
</div>
